{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.1",
  "description": "Detect risky websites and phishing links in real-time",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}